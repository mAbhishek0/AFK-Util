<Window
    x:Class="AfkBot.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AFK Bot">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          Padding="0">
        <Grid>
            <Border CornerRadius="0" Background="{ThemeResource BackdropBrush}" />

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="24"
                        Padding="48"
                        MaxWidth="520">

                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="🎮"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="AFK Bot"
                               FontSize="36"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource HeaderTitle}"/>
                    <TextBlock Text="DirectX Hardware-Level Input Simulator"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Opacity="0.5"
                               Foreground="{ThemeResource HeaderSubtitle}"/>
                </StackPanel>

                <Border CornerRadius="12"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardBorder}"
                        Background="{ThemeResource CardBackground}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:ConnectionId='6' x:Name="StatusStrip"
                                Grid.Column="0"
                                Width="6"
                                Background="#484F58"
                                CornerRadius="12,0,0,12"
                                VerticalAlignment="Stretch"/>

                        <StackPanel Grid.Column="1"
                                    Spacing="12"
                                    Padding="24,20">

                            <TextBlock Text="STATUS"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       CharacterSpacing="120"
                                       Foreground="{ThemeResource HeaderSubtitle}"
                                       HorizontalAlignment="Center"/>

                            <TextBlock x:ConnectionId='7' x:Name="StatusText"
                                       Text="Ready"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource HeaderTitle}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>

                            <Border x:ConnectionId='8' x:Name="ActiveKeyBorder"
                                    CornerRadius="8"
                                    Padding="16,10"
                                    HorizontalAlignment="Center"
                                    Opacity="0"
                                    Height="40"
                                    Width="180">
                                <Border.Background>
                                    <SolidColorBrush Color="#1F6FEB" Opacity="0.15"/>
                                </Border.Background>
                                <Grid HorizontalAlignment="Center" Width="140">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:ConnectionId='10' x:Name="ActiveKeyLabel"
                                               Grid.Column="0"
                                               Text="Idle"
                                               FontSize="14"
                                               FontFamily="Cascadia Code, Consolas, monospace"
                                               Foreground="#58A6FF"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                               Text="·"
                                               FontSize="14"
                                               FontFamily="Cascadia Code, Consolas, monospace"
                                               Foreground="#58A6FF"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <TextBlock x:ConnectionId='11' x:Name="ActiveKeyTime"
                                               Grid.Column="2"
                                               Text="0s"
                                               FontSize="14"
                                               FontFamily="Cascadia Code, Consolas, monospace"
                                               Foreground="#58A6FF"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <TextBlock x:ConnectionId='9' x:Name="LoopCountText"
                                       Text="Cycle --"
                                       FontSize="12"
                                       Foreground="{ThemeResource FooterText}"
                                       HorizontalAlignment="Center"
                                       Opacity="0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:ConnectionId='4' x:Name="StartButton"
                            Grid.Column="0"
                                                     
                            HorizontalAlignment="Stretch"
                            Height="52"
                            CornerRadius="10">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#238636" Offset="0"/>
                                            <GradientStop Color="#2EA043" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE768;" FontSize="16"/>
                            <TextBlock Text="Start" FontWeight="SemiBold" FontSize="15"/>
                        </StackPanel>
                    </Button>

                    <Button x:ConnectionId='5' x:Name="StopButton"
                            Grid.Column="1"
                                                    
                            HorizontalAlignment="Stretch"
                            Height="52"
                            CornerRadius="10"
                            IsEnabled="False">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#DA3633" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#F85149"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE71A;" FontSize="16"/>
                            <TextBlock Text="Stop" FontWeight="SemiBold" FontSize="15"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Border CornerRadius="10"
                        Padding="16,12"
                        Height="140"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource LogBorder}"
                        Background="{ThemeResource LogBackground}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="ACTIVITY LOG"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="100"
                                   Foreground="{ThemeResource FooterText}"/>
                        <ScrollViewer x:ConnectionId='2' x:Name="LogScrollViewer"
                                      Height="80"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock x:ConnectionId='3' x:Name="LogText"
                                       Text="Waiting to start..."
                                       FontSize="12"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       Foreground="{ThemeResource HeaderSubtitle}"
                                       TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True"
                                       Margin="0,0,18,0"
                                                                        />
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <TextBlock Text="⚠ Use responsibly. Run as Administrator for best results."
                           FontSize="11"
                           Foreground="{ThemeResource FooterText}"
                           HorizontalAlignment="Center"
                           Opacity="0.7"/>

            </StackPanel>
        </Grid>
    </Grid>
</Window>

