<Application
    x:Class="AfkBot.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AfkBot">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="CardBackground" Color="#0D1117" Opacity="0.7"/>
                    <SolidColorBrush x:Key="CardBorder" Color="#30363D"/>
                    <SolidColorBrush x:Key="LogBorder" Color="#21262D"/>
                    <SolidColorBrush x:Key="LogBackground" Color="#0D1117" Opacity="0.5"/>
                    <SolidColorBrush x:Key="HeaderTitle" Color="#C9D1D9"/>
                    <SolidColorBrush x:Key="HeaderSubtitle" Color="#8B949E"/>
                    <SolidColorBrush x:Key="FooterText" Color="#484F58"/>
                    <LinearGradientBrush x:Key="BackdropBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF0D1117" Offset="0.0"/>
                        <GradientStop Color="#FF161B22" Offset="0.5"/>
                        <GradientStop Color="#FF0D1117" Offset="1.0"/>
                    </LinearGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CardBackground" Color="#F6F8FA" Opacity="0.7"/>
                    <SolidColorBrush x:Key="CardBorder" Color="#D0D7DE"/>
                    <SolidColorBrush x:Key="LogBorder" Color="#D0D7DE"/>
                    <SolidColorBrush x:Key="LogBackground" Color="#F6F8FA" Opacity="0.5"/>
                    <SolidColorBrush x:Key="HeaderTitle" Color="#24292F"/>
                    <SolidColorBrush x:Key="HeaderSubtitle" Color="#57606A"/>
                    <SolidColorBrush x:Key="FooterText" Color="#6E7781"/>
                    <LinearGradientBrush x:Key="BackdropBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFF6F8FA" Offset="0.0"/>
                        <GradientStop Color="#FFEAF0F6" Offset="0.5"/>
                        <GradientStop Color="#FFF6F8FA" Offset="1.0"/>
                    </LinearGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CardBackground" Color="#0D1117" Opacity="0.7"/>
                    <SolidColorBrush x:Key="CardBorder" Color="#30363D"/>
                    <SolidColorBrush x:Key="LogBorder" Color="#21262D"/>
                    <SolidColorBrush x:Key="LogBackground" Color="#0D1117" Opacity="0.5"/>
                    <SolidColorBrush x:Key="HeaderTitle" Color="#C9D1D9"/>
                    <SolidColorBrush x:Key="HeaderSubtitle" Color="#8B949E"/>
                    <SolidColorBrush x:Key="FooterText" Color="#484F58"/>
                    <LinearGradientBrush x:Key="BackdropBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF0D1117" Offset="0.0"/>
                        <GradientStop Color="#FF161B22" Offset="0.5"/>
                        <GradientStop Color="#FF0D1117" Offset="1.0"/>
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
